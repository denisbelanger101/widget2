<?xml version="1.0" encoding="UTF-8"?>
<Module specificationVersion="2.0">
  <ModulePrefs title="DOORS Next 7.0.3 - Project Module XLSX Exporter"
               description="Loads all modules from a selected DOORS Next project area, lets the user select modules, and exports selected module data to XLSX."
               author="M365 Copilot"
               height="820"
               scrolling="true">
    <Require feature="dynamic-height"/>
    <Require feature="setprefs"/>
  </ModulePrefs>
  <UserPref name="rmBase" display_name="RM base URL" datatype="string" default_value="https://atkinsrealis.clm.ibmcloud.com/rm"/>
  <UserPref name="projectAreaUrl" display_name="Project area URL" datatype="string" default_value=""/>
  <UserPref name="configContext" display_name="Configuration context URL" datatype="string" default_value=""/>
  <Content type="html"><![CDATA[
<!doctype html>
<html>
<head>
<meta charset="UTF-8" />
<style>
  body{font-family:Arial,Helvetica,sans-serif;margin:0;background:#f7f8fa;color:#1f2933;font-size:13px}
  .wrap{padding:14px}.card{background:white;border:1px solid #d9dee8;border-radius:10px;padding:14px;margin-bottom:12px;box-shadow:0 1px 2px rgba(0,0,0,.04)}
  h2{margin:0 0 8px;font-size:18px} h3{margin:0 0 8px;font-size:14px}.muted{color:#52606d}.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
  label{font-weight:600;margin-top:8px;display:block} input,textarea,button,select{font:inherit} input[type=text],textarea{width:100%;box-sizing:border-box;border:1px solid #cbd2d9;border-radius:6px;padding:8px;background:#fff}
  button{background:#0f62fe;color:#fff;border:0;border-radius:6px;padding:8px 12px;cursor:pointer;font-weight:600}button.secondary{background:#52606d}button.danger{background:#b42318}button:disabled{background:#aeb8c2;cursor:not-allowed}
  .list{max-height:310px;overflow:auto;border:1px solid #d9dee8;border-radius:8px;background:#fbfcfe;padding:8px}.item{display:flex;gap:8px;border-bottom:1px solid #edf0f4;padding:7px 4px}.item:last-child{border-bottom:0}.uri{font-size:11px;color:#66788a;word-break:break-all}.ok{color:#027a48}.err{color:#b42318}.log{white-space:pre-wrap;background:#111827;color:#e5e7eb;border-radius:8px;padding:10px;max-height:190px;overflow:auto;font-size:12px}.pill{border:1px solid #cbd2d9;border-radius:20px;padding:2px 8px;background:#f2f4f7;color:#334e68}.search{max-width:420px}.count{font-weight:700}
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <h2>DOORS Next OSLC Project Module XLSX Exporter</h2>
    <div class="muted">Loads the module names from a DOORS Next project area, displays them in a selectable list, then exports selected modules to XLSX.</div>
  </div>

  <div class="card">
    <h3>1. Project connection</h3>
    <label>RM base URL</label><input id="rmBase" type="text" />
    <label>Project area URL</label><input id="projectAreaUrl" type="text" placeholder="https://.../rm/process/project-areas/_xxxxx" />
    <label>Configuration context URL / stream URL</label><input id="configContext" type="text" placeholder="https://.../rm/cm/stream/_xxxxx" />
    <div class="muted">Tip: copy the project area URL from a DOORS Next module/page URL parameter named <code>componentURI</code> or from project properties. Copy the stream from <code>oslc_config.context</code>.</div>
    <div class="row" style="margin-top:10px">
      <button onclick="loadModulesFromProject()">Load all modules from project area</button>
      <button class="secondary" onclick="savePrefs()">Save values</button>
    </div>
  </div>

  <div class="card">
    <h3>2. Select modules</h3>
    <div class="row" style="margin-bottom:8px">
      <input id="filter" class="search" type="text" placeholder="Filter module names..." oninput="renderModules()" />
      <button class="secondary" onclick="selectVisible(true)">Select visible</button>
      <button class="secondary" onclick="selectVisible(false)">Clear visible</button>
      <button class="danger" onclick="clearModules()">Remove all</button>
      <span class="pill"><span id="loadedCount" class="count">0</span> loaded</span>
      <span class="pill"><span id="selectedCount" class="count">0</span> selected</span>
    </div>
    <div id="modules" class="list"></div>
  </div>

  <div class="card">
    <h3>3. Export</h3>
    <div class="row"><button id="exportBtn" onclick="exportSelected()">Export selected modules to XLSX</button><span id="status" class="muted"></span></div>
    <p class="muted">The XLSX contains sheets: <b>Modules</b>, <b>Artifacts</b>, and <b>Export Log</b>. Content is limited to OSLC-visible data available to the signed-in user and selected configuration context.</p>
    <div id="log" class="log"></div>
  </div>
</div>
<script>
var prefs = new gadgets.Prefs();
var modules = [];
function init(){ document.getElementById('rmBase').value=prefs.getString('rmBase')||'https://atkinsrealis.clm.ibmcloud.com/rm'; document.getElementById('projectAreaUrl').value=prefs.getString('projectAreaUrl')||''; document.getElementById('configContext').value=prefs.getString('configContext')||''; renderModules(); resize(); }
function savePrefs(){ try{ prefs.set('rmBase',document.getElementById('rmBase').value.trim()); prefs.set('projectAreaUrl',document.getElementById('projectAreaUrl').value.trim()); prefs.set('configContext',document.getElementById('configContext').value.trim()); status('Values saved.','ok'); }catch(e){ status('Could not save preferences: '+e.message,'err'); } }
function resize(){ try{ gadgets.window.adjustHeight(); }catch(e){} }
function log(s){ var el=document.getElementById('log'); el.textContent += s + "\n"; el.scrollTop=el.scrollHeight; }
function status(s, cls){ var el=document.getElementById('status'); el.className=cls||'muted'; el.textContent=s; }
function esc(s){return String(s||'').replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
function normalizeUrl(u){ return (u||'').trim().replace(/#.*$/,''); }
function withConfig(u){ var cfg=document.getElementById('configContext').value.trim(); if(!cfg) return u; if(u.indexOf('oslc_config.context=')>=0) return u; var sep=u.indexOf('?')>=0?'&':'?'; return u + sep + 'oslc_config.context=' + encodeURIComponent(cfg); }
function makeReq(url, accept){ return new Promise(function(resolve,reject){ var params={}; params[gadgets.io.RequestParameters.METHOD]=gadgets.io.MethodType.GET; params[gadgets.io.RequestParameters.CONTENT_TYPE]=gadgets.io.ContentType.TEXT; params[gadgets.io.RequestParameters.AUTHORIZATION]=gadgets.io.AuthorizationType.SIGNED; params[gadgets.io.RequestParameters.HEADERS]={'Accept': accept || 'application/rdf+xml, application/xml, text/xml, */*','OSLC-Core-Version':'2.0'}; gadgets.io.makeRequest(url,function(resp){ if(resp.errors && resp.errors.length){ reject(new Error(resp.errors.join('; '))); return;} if(resp.rc && (resp.rc<200 || resp.rc>=300)){ reject(new Error('HTTP '+resp.rc+' '+(resp.text||''))); return;} resolve(resp.text||''); },params); }); }
function buildProjectModuleQuery(){ var base=document.getElementById('rmBase').value.trim().replace(/\/$/,''); var project=document.getElementById('projectAreaUrl').value.trim(); if(!base) throw new Error('RM base URL is required.'); if(!project) throw new Error('Project area URL is required.'); var q=base+'/views?oslc.query=true' + '&projectURL=' + encodeURIComponent(project) + '&oslc.prefix=' + encodeURIComponent('rdf=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>,oslc_rm=<http://open-services.net/xmlns/rm/1.0/>') + '&oslc.where=' + encodeURIComponent('rdf:type=oslc_rm:RequirementCollection') + '&oslc.select=' + encodeURIComponent('dcterms:title,dcterms:identifier,*'); return withConfig(q); }
async function loadModulesFromProject(){ document.getElementById('log').textContent=''; status('Loading modules from project area...'); modules=[]; renderModules(); try{ savePrefs(); var q=buildProjectModuleQuery(); log('OSLC query: '+q); var txt=await makeReq(q); var found=parseResourceRefs(txt); found.sort(function(a,b){return String(a.title).localeCompare(String(b.title));}); found.forEach(function(r){ addModule(r.uri,r.title); }); renderModules(); status('Loaded '+found.length+' module(s).','ok'); if(!found.length){ log('No RequirementCollection resources were returned. Verify projectAreaUrl, stream/configuration context, permissions, and whether modules are exposed as requirement collections in this project.'); } }catch(e){ status('Load failed.','err'); log('ERROR: '+e.message); } }
function addModule(uri,title){ uri=normalizeUrl(uri); if(!uri)return; if(modules.some(function(m){return m.uri===uri;}))return; modules.push({uri:uri,title:title||uri,selected:false}); }
function clearModules(){ modules=[]; renderModules(); }
function visibleIndexes(){ var f=(document.getElementById('filter').value||'').toLowerCase(); var idx=[]; modules.forEach(function(m,i){ if(!f || String(m.title+' '+m.uri).toLowerCase().indexOf(f)>=0) idx.push(i); }); return idx; }
function selectVisible(v){ visibleIndexes().forEach(function(i){modules[i].selected=v;}); renderModules(); }
function renderModules(){ var c=document.getElementById('modules'), idx=visibleIndexes(); document.getElementById('loadedCount').textContent=modules.length; document.getElementById('selectedCount').textContent=modules.filter(function(m){return m.selected;}).length; if(!modules.length){ c.innerHTML='<span class="muted">No module loaded yet. Click <b>Load all modules from project area</b>.</span>'; resize(); return;} if(!idx.length){ c.innerHTML='<span class="muted">No module matches the filter.</span>'; resize(); return;} c.innerHTML=idx.map(function(i){ var m=modules[i]; return '<div class="item"><input type="checkbox" '+(m.selected?'checked':'')+' onchange="modules['+i+'].selected=this.checked;renderModules();"><div><b>'+esc(m.title)+'</b><div class="uri">'+esc(m.uri)+'</div></div></div>';}).join(''); resize(); }
function parseXML(txt){ return new DOMParser().parseFromString(txt,'application/xml'); }
function textOf(node,names){ for(var i=0;i<names.length;i++){ var xs=node.getElementsByTagName(names[i]); if(xs && xs.length && xs[0].textContent) return xs[0].textContent.trim(); } return ''; }
function parseResourceRefs(txt){ var doc=parseXML(txt); var out=[]; var nodes=doc.getElementsByTagName('*'); for(var i=0;i<nodes.length;i++){ var n=nodes[i]; var about=n.getAttribute('rdf:about')||n.getAttribute('about'); if(about && /\/rm\/resources\//.test(about)){ var title=textOf(n,['dcterms:title','dc:title','title'])||about; out.push({uri:about,title:title}); } var res=n.getAttribute('rdf:resource')||n.getAttribute('resource'); if(res && /\/rm\/resources\//.test(res)){ out.push({uri:res,title:res}); } } var seen={}; return out.filter(function(x){ if(seen[x.uri])return false; seen[x.uri]=1; return true;}); }
function parseModule(uri,txt){ var doc=parseXML(txt); var title=textOf(doc,['dcterms:title','dc:title','title'])||uri; var id=textOf(doc,['dcterms:identifier','identifier']); var modified=textOf(doc,['dcterms:modified','modified']); var members=[]; var nodes=doc.getElementsByTagName('*'); for(var i=0;i<nodes.length;i++){ var n=nodes[i]; if(/uses$/i.test(n.nodeName) || /member$/i.test(n.nodeName) || /contains$/i.test(n.nodeName)){ var r=n.getAttribute('rdf:resource')||n.getAttribute('resource'); if(r && /\/rm\/resources\//.test(r) && r!==uri) members.push({uri:r,title:r}); } }
 var seen={}; members=members.filter(function(x){ if(seen[x.uri])return false; seen[x.uri]=1; return true;}); return {module:{Title:title,Identifier:id,URI:uri,Modified:modified},members:members}; }
async function exportSelected(){ document.getElementById('log').textContent=''; var sel=modules.filter(function(m){return m.selected;}); if(!sel.length){status('Select at least one module.','err');return;} status('Exporting '+sel.length+' module(s)...'); document.getElementById('exportBtn').disabled=true; var moduleRows=[], artifactRows=[], logRows=[]; for(var i=0;i<sel.length;i++){ var m=sel[i]; try{ log('GET '+m.uri); var txt=await makeReq(withConfig(m.uri)); var parsed=parseModule(m.uri,txt); moduleRows.push(parsed.module); parsed.members.forEach(function(a,idx){ artifactRows.push({ModuleTitle:parsed.module.Title,ModuleURI:m.uri,Sequence:idx+1,ArtifactURI:a.uri}); }); logRows.push({Level:'INFO',Message:'Exported '+parsed.members.length+' OSLC member/use resource(s)',URI:m.uri}); }catch(e){ moduleRows.push({Title:m.title,Identifier:'',URI:m.uri,Modified:''}); logRows.push({Level:'ERROR',Message:e.message,URI:m.uri}); log('ERROR '+m.uri+' -> '+e.message); } }
 var wb={'Modules':moduleRows,'Artifacts':artifactRows,'Export Log':logRows}; var blob=xlsxBlob(wb); downloadBlob(blob,'doors-next-project-module-export-'+dateStamp()+'.xlsx'); status('XLSX generated.','ok'); document.getElementById('exportBtn').disabled=false; }
function dateStamp(){ var d=new Date(),p=function(n){return (n<10?'0':'')+n}; return d.getFullYear()+p(d.getMonth()+1)+p(d.getDate())+'-'+p(d.getHours())+p(d.getMinutes()); }
function downloadBlob(blob,name){ var a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=name; document.body.appendChild(a); a.click(); setTimeout(function(){URL.revokeObjectURL(a.href);a.remove();},500); }
function xlsxBlob(sheets){ var files={}; files['[Content_Types].xml']='<?xml version="1.0" encoding="UTF-8"?><Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types"><Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/><Default Extension="xml" ContentType="application/xml"/><Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>'+Object.keys(sheets).map(function(n,i){return '<Override PartName="/xl/worksheets/sheet'+(i+1)+'.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>';}).join('')+'</Types>'; files['_rels/.rels']='<?xml version="1.0" encoding="UTF-8"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/></Relationships>'; files['xl/_rels/workbook.xml.rels']='<?xml version="1.0" encoding="UTF-8"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">'+Object.keys(sheets).map(function(n,i){return '<Relationship Id="rId'+(i+1)+'" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet'+(i+1)+'.xml"/>';}).join('')+'</Relationships>'; files['xl/workbook.xml']='<?xml version="1.0" encoding="UTF-8"?><workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><sheets>'+Object.keys(sheets).map(function(n,i){return '<sheet name="'+xmlEsc(n.substring(0,31))+'" sheetId="'+(i+1)+'" r:id="rId'+(i+1)+'"/>';}).join('')+'</sheets></workbook>'; var i=1; Object.keys(sheets).forEach(function(name){ files['xl/worksheets/sheet'+(i++)+'.xml']=sheetXml(sheets[name]); }); return new Blob([zipStore(files)],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'}); }
function sheetXml(rows){ rows=rows||[]; var headers=[]; rows.forEach(function(r){Object.keys(r).forEach(function(k){if(headers.indexOf(k)<0)headers.push(k);});}); if(!headers.length)headers=['No data']; var data=[headers].concat(rows.map(function(r){return headers.map(function(h){return r[h]||'';});})); return '<?xml version="1.0" encoding="UTF-8"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetData>'+data.map(function(row,ri){return '<row r="'+(ri+1)+'">'+row.map(function(v,ci){return '<c r="'+col(ci)+(ri+1)+'" t="inlineStr"><is><t>'+xmlEsc(String(v))+'</t></is></c>';}).join('')+'</row>';}).join('')+'</sheetData></worksheet>'; }
function col(n){ var s=''; n++; while(n){ var m=(n-1)%26; s=String.fromCharCode(65+m)+s; n=Math.floor((n-m)/26);} return s; }
function xmlEsc(s){return String(s).replace(/[<>&"']/g,function(c){return {'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&apos;'}[c];});}
function crc32(str){ var c=~0, i,j; for(i=0;i<str.length;i++){ c^=str.charCodeAt(i); for(j=0;j<8;j++) c=(c>>>1)^(0xEDB88320&-(c&1)); } return (~c)>>>0; }
function zipStore(files){ var enc=new TextEncoder(), chunks=[], central=[], offset=0; function u16(n){return String.fromCharCode(n&255,(n>>>8)&255)} function u32(n){return u16(n&65535)+u16((n>>>16)&65535)} Object.keys(files).forEach(function(name){ var data=enc.encode(files[name]), nb=enc.encode(name), cr=crc32(String.fromCharCode.apply(null,data)); var local='PK\x03\x04'+u16(20)+u16(0)+u16(0)+u16(0)+u16(0)+u32(cr)+u32(data.length)+u32(data.length)+u16(nb.length)+u16(0); chunks.push(strBytes(local),nb,data); var cent='PK\x01\x02'+u16(20)+u16(20)+u16(0)+u16(0)+u16(0)+u16(0)+u32(cr)+u32(data.length)+u32(data.length)+u16(nb.length)+u16(0)+u16(0)+u16(0)+u16(0)+u32(0)+u32(offset); central.push(strBytes(cent),nb); offset += local.length + nb.length + data.length; }); var csize=central.reduce(function(a,b){return a+b.length;},0); var end='PK\x05\x06'+u16(0)+u16(0)+u16(Object.keys(files).length)+u16(Object.keys(files).length)+u32(csize)+u32(offset)+u16(0); return new Blob(chunks.concat(central).concat([strBytes(end)])); }
function strBytes(s){ var a=new Uint8Array(s.length); for(var i=0;i<s.length;i++)a[i]=s.charCodeAt(i)&255; return a; }
init();
</script>
</body>
</html>
  ]]></Content>
</Module>
