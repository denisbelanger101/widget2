<?xml version="1.0" encoding="UTF-8"?>
<Module specificationVersion="2.0">
  <ModulePrefs title="DOORS Next 7.0.3 - Module XLSX Exporter FIXED"
               description="Loads DOORS Next modules from a project area using OSLC query, then exports selected modules to XLSX. Includes diagnostics."
               author="M365 Copilot"
               height="840"
               scrolling="true">
    <Require feature="dynamic-height"/>
  </ModulePrefs>
  <UserPref name="rmBase" display_name="RM base URL" datatype="string" default_value="https://atkinsrealis.clm.ibmcloud.com/rm"/>
  <UserPref name="projectAreaUrl" display_name="Project area URL" datatype="string" default_value=""/>
  <UserPref name="configContext" display_name="Configuration context URL" datatype="string" default_value=""/>
  <Content type="html"><![CDATA[
<!doctype html>
<html>
<head>
<meta charset="UTF-8" />
<style>
body{font-family:Arial,Helvetica,sans-serif;margin:0;background:#f7f8fa;color:#1f2933;font-size:13px}.wrap{padding:14px}.card{background:#fff;border:1px solid #d9dee8;border-radius:10px;padding:14px;margin-bottom:12px}h2{margin:0 0 8px;font-size:18px}h3{margin:0 0 8px;font-size:14px}.muted{color:#52606d}.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}label{font-weight:600;margin-top:8px;display:block}input,button{font:inherit}input[type=text]{width:100%;box-sizing:border-box;border:1px solid #cbd2d9;border-radius:6px;padding:8px;background:#fff}button{background:#0f62fe;color:#fff;border:0;border-radius:6px;padding:8px 12px;cursor:pointer;font-weight:600}button.secondary{background:#52606d}button.danger{background:#b42318}button:disabled{background:#aeb8c2;cursor:not-allowed}.list{max-height:310px;overflow:auto;border:1px solid #d9dee8;border-radius:8px;background:#fbfcfe;padding:8px}.item{display:flex;gap:8px;border-bottom:1px solid #edf0f4;padding:7px 4px}.item:last-child{border-bottom:0}.uri{font-size:11px;color:#66788a;word-break:break-all}.ok{color:#027a48}.err{color:#b42318}.log{white-space:pre-wrap;background:#111827;color:#e5e7eb;border-radius:8px;padding:10px;max-height:230px;overflow:auto;font-size:12px}.pill{border:1px solid #cbd2d9;border-radius:20px;padding:2px 8px;background:#f2f4f7;color:#334e68}.search{max-width:420px}.count{font-weight:700}
</style>
</head>
<body>
<div class="wrap">
 <div class="card"><h2>DOORS Next OSLC Project Module XLSX Exporter - Fixed</h2><div class="muted">This version fixes the OSLC prefix issue and tries multiple module discovery queries. It also logs the exact HTTP response if loading fails.</div></div>
 <div class="card"><h3>1. Connection</h3>
  <label>RM base URL</label><input id="rmBase" type="text" />
  <label>Project area URL</label><input id="projectAreaUrl" type="text" placeholder="https://.../rm/process/project-areas/_xxxxx" />
  <label>Configuration context URL / stream URL - leave blank for non-CM projects</label><input id="configContext" type="text" placeholder="https://.../rm/cm/stream/_xxxxx" />
  <div class="row" style="margin-top:10px"><button onclick="loadModulesFromProject()">Load modules</button><button class="secondary" onclick="runDiagnostics()">Run diagnostics</button></div>
 </div>
 <div class="card"><h3>2. Select modules</h3>
  <div class="row" style="margin-bottom:8px"><input id="filter" class="search" type="text" placeholder="Filter module names..." oninput="renderModules()"/><button class="secondary" onclick="selectVisible(true)">Select visible</button><button class="secondary" onclick="selectVisible(false)">Clear visible</button><button class="danger" onclick="clearModules()">Remove all</button><span class="pill"><span id="loadedCount" class="count">0</span> loaded</span><span class="pill"><span id="selectedCount" class="count">0</span> selected</span></div>
  <div id="modules" class="list"></div>
 </div>
 <div class="card"><h3>3. Export</h3><div class="row"><button id="exportBtn" onclick="exportSelected()">Export selected modules to XLSX</button><span id="status" class="muted"></span></div><div id="log" class="log"></div></div>
</div>
<script>
var prefs=new gadgets.Prefs();
var modules=[];
function init(){document.getElementById('rmBase').value=prefs.getString('rmBase')||'https://atkinsrealis.clm.ibmcloud.com/rm';document.getElementById('projectAreaUrl').value=prefs.getString('projectAreaUrl')||'';document.getElementById('configContext').value=prefs.getString('configContext')||'';renderModules();resize();}
function resize(){try{gadgets.window.adjustHeight();}catch(e){}}
function log(s){var el=document.getElementById('log');el.textContent+=s+'\n';el.scrollTop=el.scrollHeight;resize();}
function status(s,cls){var el=document.getElementById('status');el.className=cls||'muted';el.textContent=s;}
function esc(s){return String(s||'').replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}
function b64(s){try{return btoa(unescape(encodeURIComponent(s)));}catch(e){return s;}}
function rmBase(){return document.getElementById('rmBase').value.trim().replace(/\/$/,'');}
function projectUrl(){return document.getElementById('projectAreaUrl').value.trim();}
function cfgUrl(){return document.getElementById('configContext').value.trim();}
function addConfig(u){var c=cfgUrl();if(!c)return u;if(u.indexOf('oslc_config.context=')>=0)return u;return u+(u.indexOf('?')>=0?'&':'?')+'oslc_config.context='+encodeURIComponent(c);}
function makeReq(url,accept){return new Promise(function(resolve,reject){var params={};params[gadgets.io.RequestParameters.METHOD]=gadgets.io.MethodType.GET;params[gadgets.io.RequestParameters.CONTENT_TYPE]=gadgets.io.ContentType.TEXT;params[gadgets.io.RequestParameters.AUTHORIZATION]=gadgets.io.AuthorizationType.SIGNED;params[gadgets.io.RequestParameters.HEADERS]={'Accept':accept||'application/rdf+xml,application/xml,text/xml,*/*','OSLC-Core-Version':'2.0'};gadgets.io.makeRequest(url,function(resp){var result={url:url,rc:resp.rc||0,text:resp.text||'',errors:resp.errors||[]};if(result.errors.length||result.rc>=400){reject(result);return;}resolve(result);},params);});}
function queryUrls(){var base=rmBase(), prj=projectUrl();if(!base)throw new Error('RM base URL is required.');if(!prj)throw new Error('Project area URL is required.');var prefV2='rdf=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>,dcterms=<http://purl.org/dc/terms/>,oslc_rm=<http://open-services.net/ns/rm#>';
var prefV1='rdf=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>,dcterms=<http://purl.org/dc/terms/>,oslc_rm=<http://open-services.net/xmlns/rm/1.0/>';
function q(prefix,where){return addConfig(base+'/views?oslc.query=true&projectURL='+encodeURIComponent(prj)+'&oslc.prefix='+encodeURIComponent(prefix)+'&oslc.where='+encodeURIComponent(where)+'&oslc.select='+encodeURIComponent('dcterms:title,dcterms:identifier,*'));}
return [q(prefV2,'rdf:type=oslc_rm:RequirementCollection'),q(prefV1,'rdf:type=oslc_rm:RequirementCollection')];}
async function runDiagnostics(){document.getElementById('log').textContent='';try{var urls=queryUrls();log('Diagnostics. CM context is '+(cfgUrl()?'SET':'EMPTY - non-CM mode'));for(var i=0;i<urls.length;i++){log('\nGET test '+(i+1)+': '+urls[i]);try{var r=await makeReq(urls[i]);log('HTTP '+r.rc+' OK. First 700 chars:\n'+r.text.substring(0,700));}catch(e){log('FAILED rc='+e.rc+' errors='+(e.errors||[]).join('; ')+' first 700 chars:\n'+String(e.text||'').substring(0,700));}}}catch(ex){log('Diagnostics error: '+ex.message);}}
async function loadModulesFromProject(){document.getElementById('log').textContent='';modules=[];renderModules();status('Loading modules...');try{var urls=queryUrls(), last='';for(var i=0;i<urls.length;i++){log('Trying module query '+(i+1)+': '+urls[i]);try{var r=await makeReq(urls[i]);last=r.text;var found=parseResources(r.text);log('Query '+(i+1)+' returned '+found.length+' resource(s).');if(found.length){found.sort(function(a,b){return a.title.localeCompare(b.title);});found.forEach(function(x){addModule(x.uri,x.title);});break;}}catch(e){log('Query '+(i+1)+' failed. HTTP '+e.rc+' '+(e.errors||[]).join('; ')+'\n'+String(e.text||'').substring(0,900));}}
renderModules();status('Loaded '+modules.length+' module(s).',modules.length?'ok':'err');if(!modules.length){log('\nNo modules loaded. Possible causes: wrong Project Area URL, missing permissions, CM context required/wrong, or this project does not expose modules as OSLC RequirementCollection through /views. Run diagnostics and send me the log.');}}
catch(e){status('Load failed.','err');log('ERROR: '+e.message);}}
function parseResources(txt){var doc=new DOMParser().parseFromString(txt,'application/xml');var out=[],nodes=doc.getElementsByTagName('*');for(var i=0;i<nodes.length;i++){var n=nodes[i],uri=n.getAttribute('rdf:about')||n.getAttribute('about');if(uri&&/\/rm\/resources\//.test(uri)){var title='';var kids=n.getElementsByTagName('*');for(var k=0;k<kids.length;k++){if(/title$/i.test(kids[k].nodeName)&&kids[k].textContent){title=kids[k].textContent.trim();break;}}out.push({uri:uri,title:title||uri});}}
var seen={};return out.filter(function(x){if(seen[x.uri])return false;seen[x.uri]=1;return true;});}
function addModule(uri,title){if(modules.some(function(m){return m.uri===uri;}))return;modules.push({uri:uri,title:title,selected:false});}
function visibleIndexes(){var f=(document.getElementById('filter').value||'').toLowerCase(),a=[];modules.forEach(function(m,i){if(!f||(m.title+' '+m.uri).toLowerCase().indexOf(f)>=0)a.push(i);});return a;}
function renderModules(){var c=document.getElementById('modules'),idx=visibleIndexes();document.getElementById('loadedCount').textContent=modules.length;document.getElementById('selectedCount').textContent=modules.filter(function(m){return m.selected;}).length;if(!modules.length){c.innerHTML='<span class="muted">No module loaded yet.</span>';resize();return;}c.innerHTML=idx.map(function(i){var m=modules[i];return '<div class="item"><input type="checkbox" '+(m.selected?'checked':'')+' onchange="modules['+i+'].selected=this.checked;renderModules();"><div><b>'+esc(m.title)+'</b><div class="uri">'+esc(m.uri)+'</div></div></div>';}).join('')||'<span class="muted">No match.</span>';resize();}
function selectVisible(v){visibleIndexes().forEach(function(i){modules[i].selected=v;});renderModules();}
function clearModules(){modules=[];renderModules();}
async function exportSelected(){var sel=modules.filter(function(m){return m.selected;});if(!sel.length){status('Select at least one module.','err');return;}status('Exporting...');var moduleRows=[],artifactRows=[],logRows=[];for(var i=0;i<sel.length;i++){var m=sel[i];try{var r=await makeReq(addConfig(m.uri));var parsed=parseModule(m.uri,r.text);moduleRows.push(parsed.module);parsed.members.forEach(function(a,idx){artifactRows.push({ModuleTitle:parsed.module.Title,ModuleURI:m.uri,Sequence:idx+1,ArtifactURI:a.uri});});logRows.push({Level:'INFO',Message:'Exported '+parsed.members.length+' member/use resources',URI:m.uri});}catch(e){moduleRows.push({Title:m.title,URI:m.uri});logRows.push({Level:'ERROR',Message:'HTTP '+e.rc+' '+(e.errors||[]).join('; '),URI:m.uri});}}
downloadBlob(xlsxBlob({'Modules':moduleRows,'Artifacts':artifactRows,'Export Log':logRows}),'doors-next-module-export-'+dateStamp()+'.xlsx');status('XLSX generated.','ok');}
function parseModule(uri,txt){var doc=new DOMParser().parseFromString(txt,'application/xml');function t(names){for(var i=0;i<names.length;i++){var xs=doc.getElementsByTagName(names[i]);if(xs.length&&xs[0].textContent)return xs[0].textContent.trim();}return '';}var title=t(['dcterms:title','dc:title','title'])||uri,id=t(['dcterms:identifier','identifier']),mod=t(['dcterms:modified','modified']);var members=[],nodes=doc.getElementsByTagName('*');for(var i=0;i<nodes.length;i++){var n=nodes[i];if(/uses$/i.test(n.nodeName)||/member$/i.test(n.nodeName)){var r=n.getAttribute('rdf:resource')||n.getAttribute('resource');if(r&&/\/rm\/resources\//.test(r)&&r!==uri)members.push({uri:r});}}var seen={};members=members.filter(function(x){if(seen[x.uri])return false;seen[x.uri]=1;return true;});return {module:{Title:title,Identifier:id,URI:uri,Modified:mod},members:members};}
function dateStamp(){var d=new Date(),p=function(n){return(n<10?'0':'')+n};return d.getFullYear()+p(d.getMonth()+1)+p(d.getDate())+'-'+p(d.getHours())+p(d.getMinutes());}
function downloadBlob(blob,name){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;document.body.appendChild(a);a.click();setTimeout(function(){URL.revokeObjectURL(a.href);a.remove();},500);}
function xlsxBlob(sheets){var files={};files['[Content_Types].xml']='<?xml version="1.0" encoding="UTF-8"?><Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types"><Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/><Default Extension="xml" ContentType="application/xml"/><Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>'+Object.keys(sheets).map(function(n,i){return '<Override PartName="/xl/worksheets/sheet'+(i+1)+'.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>';}).join('')+'</Types>';files['_rels/.rels']='<?xml version="1.0" encoding="UTF-8"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships"><Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/></Relationships>';files['xl/_rels/workbook.xml.rels']='<?xml version="1.0" encoding="UTF-8"?><Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">'+Object.keys(sheets).map(function(n,i){return '<Relationship Id="rId'+(i+1)+'" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet'+(i+1)+'.xml"/>';}).join('')+'</Relationships>';files['xl/workbook.xml']='<?xml version="1.0" encoding="UTF-8"?><workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"><sheets>'+Object.keys(sheets).map(function(n,i){return '<sheet name="'+xmlEsc(n.substring(0,31))+'" sheetId="'+(i+1)+'" r:id="rId'+(i+1)+'"/>';}).join('')+'</sheets></workbook>';var i=1;Object.keys(sheets).forEach(function(name){files['xl/worksheets/sheet'+(i++)+'.xml']=sheetXml(sheets[name]);});return new Blob([zipStore(files)],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});}
function sheetXml(rows){rows=rows||[];var headers=[];rows.forEach(function(r){Object.keys(r).forEach(function(k){if(headers.indexOf(k)<0)headers.push(k);});});if(!headers.length)headers=['No data'];var data=[headers].concat(rows.map(function(r){return headers.map(function(h){return r[h]||'';});}));return '<?xml version="1.0" encoding="UTF-8"?><worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><sheetData>'+data.map(function(row,ri){return '<row r="'+(ri+1)+'">'+row.map(function(v,ci){return '<c r="'+col(ci)+(ri+1)+'" t="inlineStr"><is><t>'+xmlEsc(String(v))+'</t></is></c>';}).join('')+'</row>';}).join('')+'</sheetData></worksheet>';}
function col(n){var s='';n++;while(n){var m=(n-1)%26;s=String.fromCharCode(65+m)+s;n=Math.floor((n-m)/26);}return s;}
function xmlEsc(s){return String(s).replace(/[<>&"']/g,function(c){return {'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&apos;'}[c];});}
function crc32(str){var c=~0,i,j;for(i=0;i<str.length;i++){c^=str.charCodeAt(i);for(j=0;j<8;j++)c=(c>>>1)^(0xEDB88320&-(c&1));}return(~c)>>>0;}
function zipStore(files){var enc=new TextEncoder(),chunks=[],central=[],offset=0;function u16(n){return String.fromCharCode(n&255,(n>>>8)&255)}function u32(n){return u16(n&65535)+u16((n>>>16)&65535)}Object.keys(files).forEach(function(name){var data=enc.encode(files[name]),nb=enc.encode(name),cr=crc32(String.fromCharCode.apply(null,data));var local='PK\x03\x04'+u16(20)+u16(0)+u16(0)+u16(0)+u16(0)+u32(cr)+u32(data.length)+u32(data.length)+u16(nb.length)+u16(0);chunks.push(strBytes(local),nb,data);var cent='PK\x01\x02'+u16(20)+u16(20)+u16(0)+u16(0)+u16(0)+u16(0)+u32(cr)+u32(data.length)+u32(data.length)+u16(nb.length)+u16(0)+u16(0)+u16(0)+u16(0)+u32(0)+u32(offset);central.push(strBytes(cent),nb);offset+=local.length+nb.length+data.length;});var csize=central.reduce(function(a,b){return a+b.length;},0);var end='PK\x05\x06'+u16(0)+u16(0)+u16(Object.keys(files).length)+u16(Object.keys(files).length)+u32(csize)+u32(offset)+u16(0);return new Blob(chunks.concat(central).concat([strBytes(end)]));}
function strBytes(s){var a=new Uint8Array(s.length);for(var i=0;i<s.length;i++)a[i]=s.charCodeAt(i)&255;return a;}
init();
</script>
</body>
</html>
  ]]></Content>
